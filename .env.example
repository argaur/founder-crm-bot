# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from: Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# The username of your bot WITHOUT the @ (e.g. foundercrm_bot)
# Used to construct deep links: https://t.me/{BOT_NAME}?start={user_id}
BOT_NAME=

# ── Airtable ───────────────────────────────────────────────────────────────────
# Personal Access Token — create at: airtable.com/account → Developer Hub → Personal Access Tokens
# Required scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_PAT=

# Base ID — visible in the URL when you open your base: airtable.com/{BASE_ID}/...
AIRTABLE_BASE_ID=

# ── AI APIs ────────────────────────────────────────────────────────────────────
# Anthropic Claude — get from: console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI Whisper — get from: platform.openai.com
OPENAI_API_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
# Public URL of this Railway service (no trailing slash)
# Set AFTER deploying to Railway — Railway shows you the URL in the dashboard
# Example: https://founder-crm-production.up.railway.app
APP_BASE_URL=
